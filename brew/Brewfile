# Brewfile - Neovim setup dependencies
# Install with: brew bundle --file=~/.config/brew/Brewfile

# ============================================
# Core tools
# ============================================
brew "neovim"
brew "git"
brew "tmux"

# ============================================
# Shell & terminal
# ============================================
brew "fish"
brew "starship"
brew "zoxide"
brew "bat"
brew "lsd"

# ============================================
# Search & navigation (used by neovim plugins)
# ============================================
brew "fzf"
