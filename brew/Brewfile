brew "fd"

# ============================================
# Language runtimes
# ============================================
brew "go"
brew "node"
brew "python@3"
brew "ruby"
brew "lua"
brew "bun"

# ============================================
# Formatters & linters (system-level)
# Mason installs most of these, but having
# them in brew ensures they're available
# globally and for Mason bootstrapping.
# ============================================
